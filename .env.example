# Required — Set these in Railway dashboard
NODE_ENV=production
PORT=5000
DATABASE_URL=./data.db

# Stripe — Get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Admin Panel — Set your own secure password
ADMIN_PASSWORD=change-me-to-something-secure
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# Optional: Perplexity API for real AI responses
PERPLEXITY_API_KEY=pplx-...
